{
  "name": "prosemirror-enter-rules",
  "type": "module",
  "version": "0.1.6",
  "packageManager": "pnpm@11.10.0",
  "description": "Enter rules for ProseMirror",
  "author": "ocavue <ocavue@gmail.com>",
  "license": "MIT",
  "funding": "https://github.com/sponsors/ocavue",
  "homepage": "https://github.com/ocavue/prosemirror-enter-rules#readme",
  "repository": {
    "type": "git",
    "url": "https://github.com/ocavue/prosemirror-enter-rules.git"
  },
  "bugs": "https://github.com/ocavue/prosemirror-enter-rules/issues",
  "keywords": [
    "ProseMirror"
  ],
  "sideEffects": false,
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch",
    "lint": "eslint .",
    "fix": "eslint --fix . && prettier --write .",
    "test": "vitest",
    "typecheck": "tsc -b"
  },
  "dependencies": {
    "prosemirror-keymap": "^1.2.3",
    "prosemirror-model": "^1.25.10",
    "prosemirror-state": "^1.4.4",
    "prosemirror-view": "^1.42.0"
  },
  "devDependencies": {
    "@ocavue/eslint-config": "^4.11.0",
    "@ocavue/tsconfig": "^0.7.1",
    "@types/node": "^20.19.10",
    "eslint": "^10.6.0",
    "jsdom": "^29.0.0",
    "prettier": "^3.9.4",
    "tsdown": "^0.22.0",
    "typescript": "^6.0.0",
    "vite": "^8.0.0",
    "vitest": "^4.1.10"
  }
}
