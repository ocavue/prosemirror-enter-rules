{
  "name": "prosemirror-enter-rules",
  "type": "module",
  "version": "0.1.5",
  "packageManager": "pnpm@10.33.0",
  "description": "Enter rules for ProseMirror",
  "author": "ocavue <ocavue@gmail.com>",
  "license": "MIT",
  "funding": "https://github.com/sponsors/ocavue",
  "homepage": "https://github.com/ocavue/prosemirror-enter-rules#readme",
  "repository": {
    "type": "git",
    "url": "https://github.com/ocavue/prosemirror-enter-rules.git"
  },
  "bugs": "https://github.com/ocavue/prosemirror-enter-rules/issues",
  "keywords": [
    "ProseMirror"
  ],
  "sideEffects": false,
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "typesVersions": {
    "*": {
      "*": [
        "./dist/*",
        "./dist/index.d.ts"
      ]
    }
  },
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch",
    "lint": "eslint .",
    "fix": "eslint --fix . && prettier --write .",
    "test": "vitest",
    "typecheck": "tsc -b"
  },
  "dependencies": {
    "prosemirror-keymap": "^1.2.3",
    "prosemirror-model": "^1.25.4",
    "prosemirror-state": "^1.4.4",
    "prosemirror-view": "^1.41.8"
  },
  "devDependencies": {
    "@ocavue/eslint-config": "^4.5.2",
    "@ocavue/tsconfig": "^0.7.1",
    "@types/node": "^20.19.10",
    "eslint": "^10.2.0",
    "jsdom": "^28.1.0",
    "prettier": "^3.8.1",
    "tsdown": "^0.21.7",
    "typescript": "^5.9.3",
    "vite": "^7.3.2",
    "vitest": "^4.1.3"
  }
}
